{
  "version": 2,
  "builds": [
    { "src": "index.html",     "use": "@vercel/static" },
    { "src": "style.css",      "use": "@vercel/static" },
    { "src": "app.js",         "use": "@vercel/static" },
    { "src": "api/process.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/process", "dest": "/api/process.py" },
    { "src": "/",            "dest": "/index.html"     },
    { "src": "/(.*)",        "dest": "/$1"             }
  ]
}
